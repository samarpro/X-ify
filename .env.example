# Copy to ".env" and adjust. Loaded automatically by Settings() (CLI, API, scraper).

# -----------------------------------------------------------------------------
# Playwright / X session (persistent Chromium profile)
# -----------------------------------------------------------------------------
# Full path to profile folder: .../<userDataRoot>/<ProfileName> (last segment =
# Chromium --profile-directory). Omit to use the OS default under your home dir.
# X_USER_DATA_DIR=

# Use installed Google Chrome instead of bundled Chromium (common values: chrome, msedge).
# PLAYWRIGHT_CHANNEL=

# -----------------------------------------------------------------------------
# LLM (optional ranking after rule filter)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# -----------------------------------------------------------------------------
# Local HTTP API (uvicorn)
# -----------------------------------------------------------------------------
API_HOST=127.0.0.1
API_PORT=8765
# If non-empty, POST /scrape requires header: X-API-Token: <same value>
API_TOKEN=
